{
  "dependencies": {
    "@supabase/supabase-js": "^2.110.6",
    "axios": "^0.21.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^10.0.0",
    "express": "^4.17.1",
    "express-async-handler": "^1.1.4",
    "google-auth-library": "^9.15.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.2",
    "postgres": "^3.4.9",
    "stripe": "^18.2.1"
  },
  "name": "aims-commerce",
  "type": "module",
  "version": "1.0.0",
  "main": "index.js",
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@prisma/client": "^7.8.0",
    "nodemon": "^2.0.12",
    "prisma": "^7.8.0",
    "tsx": "^4.23.1"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": "10.8.2"
  },
  "scripts": {
    "build": "yarn install",
    "start": "node backend/server.js",
    "run-scripts": "node backend/scripts/syncProductSellers.js",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:reset": "npx prisma migrate reset --force && npx tsx prisma/seed.ts",
    "db:dump": "node scripts/dumpMongo.mjs",
    "db:migrate": "node scripts/migrateMongoToSupabase.mjs --truncate",
    "db:storage": "node scripts/setupSupabaseStorage.mjs",
    "db:chat-migration": "node scripts/applyChatMigration.mjs",
    "test:e2e": "node scripts/e2e_test.mjs",
    "test:chat": "node scripts/chat_test.mjs",
    "test:all": "node scripts/e2e_test.mjs && node scripts/chat_test.mjs"
  },
  "author": "Amirsali Muhalli",
  "license": "ISC",
  "description": "aims-commerce backend",
  "repository": "https://github.com/muhallimir/aims-commerce-backend"
}
